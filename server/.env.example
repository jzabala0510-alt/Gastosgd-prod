PORT=3101

# Conexion a la BD - SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=
DB_NAME=Ardene          # dev: Ardene  |  prod: GASTOSGD (BD propia de la app)
DB_GENERAL=GENERAL
DB_ENCRYPT=false
DB_TRUST_CERT=true
ARDENE_CODEMPRESA=25

# Host de las BD de marca. dev: localhost (copias locales). prod: el server real
# (p. ej. 172.16.20.30) para que TODAS las marcas conecten ahi. Vacio = usar el host del PATHBD.
DB_FORCE_HOST=localhost

# Auth
JWT_SECRET=
JWT_EXPIRES=8h

# Adjuntos
UPLOAD_DIR=./uploads

# Actualizador (Admin -> seccion /actualizador, clave propia, no ligada a ICG)
# Descarga el .zip del branch indicado de un repo PUBLICO de GitHub y lo aplica.
UPDATER_PASSWORD=
UPDATE_REPO_OWNER=
UPDATE_REPO_NAME=
UPDATE_REPO_BRANCH=main
